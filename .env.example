# URL base de la API del backend (entregada por el TA). Incluye el prefijo /api/v1.
# En desarrollo local con el mock, puedes dejarlo como /api (el dev server hace proxy).
VITE_API_BASE_URL=/api/v1

# Credenciales del equipo (solo para autocompletar el login en desarrollo).
# NO son necesarias en produccion; el login se hace en la UI.
VITE_TEAM_CODE=TEAM-001
VITE_EMAIL=operator@tuckersoft.com
VITE_PASSWORD=password-del-equipo
